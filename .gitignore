# Crash artifacts — ELF core dumps and heap snapshots may contain
# env-var-resident secrets (Copilot/GitHub/Azure tokens) from the
# crashed process memory. Never commit them.
core
core.*
*.core
*.dmp
*.mdmp
*.hprof
*.heap
*.heapsnapshot

